{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "autoshare": false,
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 4096
  },
  "experimental": {
    "batch_tool": true,
    "openTelemetry": false
  },
  "formatter": {
    "prettier": {
      "command": ["npx", "prettier", "--write", "--config", "./.prettierrc", "$FILE"],
      "extensions": [".js", ".ts", ".jsx", ".tsx", ".json", ".jsonc", ".css", ".md", ".yml", ".yaml"]
    }
  },
  "logLevel": "DEBUG",
  "enabled_providers": ["x-openai", "x-google", "x-anthropic"],
  "provider": {
    "x-openai": {
      "models": {
        "LongCat-Flash-Chat": {
          "name": "LongCat-Flash-Chat"
        },
        "LongCat-Flash-Thinking": {
          "name": "LongCat-Flash-Thinking"
        },
        "LongCat-Flash-Lite": {
          "name": "LongCat-Flash-Lite"
        },
        "LongCat-Pro-Preview": {
          "name": "LongCat-Pro-Preview"
        },
        "z-ai/glm4.7": {
          "name": "z-ai/glm4.7"
        },
        "z-ai/glm5": {
          "name": "z-ai/glm5"
        },
        "z-ai/glm-5.1": {
          "name": "z-ai/glm-5.1"
        },
        "qwen/qwen3-coder-480b-a35b-instruct": {
          "name": "qwen/qwen3-coder-480b-a35b-instruct"
        },
        "qwen/qwen3.5-397b-a17b": {
          "name": "qwen/qwen3.5-397b-a17b"
        },
        "qwen/qwen3.5-122b-a10b": {
          "name": "qwen/qwen3.5-122b-a10b"
        },
        "qwen-3-235b-a22b-instruct-2507": {
          "name": "qwen-3-235b-a22b-instruct-2507"
        },
        "minimaxai/minimax-m2.5": {
          "name": "minimaxai/minimax-m2.5"
        },
        "minimaxai/minimax-m2.7": {
          "name": "minimaxai/minimax-m2.7"
        },
        "moonshotai/kimi-k2.5": {
          "name": "moonshotai/kimi-k2.5"
        },
        "minimax-m2.7": {
          "name": "minimax-m2.7"
        },
        "glm-5.1": {
          "name": "glm-5.1"
        },
        "glm-5": {
          "name": "glm-5"
        },
        "qwen3.5:397b": {
          "name": "qwen3.5:397b"
        },
        "kimi-k2.6": {
          "name": "kimi-k2.6"
        }
      },
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "apiKey": "{env:API_KEY}",
        "baseURL": "https://airfly.dpdns.org/v1"
      }
      // "options": {
      //   "apiKey": "{env:API_KEY}",
      //   "baseURL": "https://cors-proxy.chatboxai.app/proxy-api/completions?",
      //   "headers": {
      //     "chatbox-platform": "desktop",
      //     "chatbox-version": "1.818.4",
      //     "chatbox-target-uri": "https://airfly.dpdns.org/v1/chat/completions"
      //   }
      // }
    },
    "x-google": {
      "models": {
        "gemini-3.1-flash-live-preview": {
          "name": "gemini-3.1-flash-live-preview"
        },
        "gemini-3-flash-preview": {
          "name": "gemini-3-flash-preview"
        },
        "gemini-2.5-flash": {
          "name": "gemini-2.5-flash"
        },
        "gemini-2.5-flash-lite": {
          "name": "gemini-2.5-flash-lite"
        },
        "gemini-flash-lite-latest": {
          "name": "gemini-flash-lite-latest"
        },
        "gemma-4-31b-it": {
          "name": "gemma-4-31b-it"
        }
      },
      "npm": "@ai-sdk/google",
      "options": {
        "apiKey": "{env:API_KEY}",
        "baseURL": "https://airfly.dpdns.org/v1beta"
      }
    },
    "x-anthropic": {
      "models": {
        "LongCat-Flash-Chat": {
          "name": "LongCat-Flash-Chat"
        },
        "LongCat-Flash-Thinking": {
          "name": "LongCat-Flash-Thinking"
        },
        "LongCat-Flash-Lite": {
          "name": "LongCat-Flash-Lite"
        }
      },
      "npm": "@ai-sdk/anthropic",
      "options": {
        "apiKey": "{env:API_KEY}",
        "baseURL": "https://airfly.dpdns.org"
      }
    }
  },
  "plugin": ["oh-my-openagent@latest", "@tarquinen/opencode-dcp@latest"],
  "mcp": {
    "tavily": {
      "type": "remote",
      "url": "https://mcp.tavily.com/mcp/?tavilyApiKey={env:TAVILY_API_KEY}",
      "enabled": true
    },
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp", "--api-key", "{env:CONTEXT7_API_KEY}"],
      "enabled": true
    }
  }
}
